{
    "name": "rgn-website",
    "version": "1.0.0",
    "description": "RGN Website - Unlimited Connection",
    "scripts": {
      "build": "bash build-wasmer.sh",
      "deploy": "wasmer deploy",
      "dev": "hugo server -D --watch --port=1313",
      "wasm-build": "GOOS=wasip1 GOARCH=wasm CGO_ENABLED=0 go build -o target/wasm32-wasi/release/rgn-server.wasm main_wasm.go",
      "wasm-run": "wasmer run target/wasm32-wasi/release/rgn-server.wasm --net --env PORT=8080",
      "wasm-package": "tar -czf rgn-website.wasmer.tar.gz -C target ."
    },
    "keywords": ["wasmer", "webassembly", "hugo", "go", "website"],
    "author": "RGN Team",
    "license": "MIT"
  }